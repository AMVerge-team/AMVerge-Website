# ============================================================
# AMVerge Website (public site) env example
# Copy to `.env` (gitignored). VITE_* vars are bundled and public.
# ============================================================

# Base URL of the backend that serves docs content (and notifications).
# This is the AMVerge-Website-Admin backend (counter-server.cjs), no trailing slash.
#   dev:  http://localhost:3001
#   prod: https://admin.amverge.app   (or wherever that backend is deployed)
VITE_ADMIN_API_URL=http://localhost:3001
